rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default open to authenticated users for existing collections
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Specifically protect private subcollections
    match /User/{userId}/private/{privateDoc} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
